{
  "service": {
    "description": "Networked or deployable service with operational runtime expectations.",
    "applicability_overrides": {
      "security_posture": "applicable",
      "maintainability_operability": "applicable",
      "dependency_release_hygiene": "applicable"
    },
    "expectations": [
      "input validation",
      "runtime error discipline",
      "observability",
      "health behavior",
      "release and deployment hygiene"
    ]
  },
  "library": {
    "description": "Reusable package or module intended to be imported by another codebase.",
    "applicability_overrides": {
      "security_posture": "partially_applicable",
      "maintainability_operability": "partially_applicable",
      "dependency_release_hygiene": "applicable"
    },
    "expectations": [
      "API stability",
      "versioning hygiene",
      "test coverage for exported surface",
      "package truthfulness"
    ]
  },
  "cli": {
    "description": "Command-line tool where console output can be legitimate and service-specific expectations may not apply.",
    "applicability_overrides": {
      "security_posture": "applicable",
      "maintainability_operability": "partially_applicable",
      "dependency_release_hygiene": "applicable"
    },
    "expectations": [
      "safe command execution",
      "argument validation",
      "path handling",
      "reasonable UX logging"
    ]
  },
  "monorepo": {
    "description": "Repository containing multiple packages, services, or tools that require scoped interpretation.",
    "applicability_overrides": {
      "architecture_design": "applicable",
      "dependency_release_hygiene": "applicable",
      "maintainability_operability": "applicable"
    },
    "expectations": [
      "clear boundaries",
      "workspace hygiene",
      "scoped CI",
      "versioning strategy"
    ]
  },
  "research_repo": {
    "description": "Experimental or academic repository centered on exploration, experiments, or prototype artifacts.",
    "applicability_overrides": {
      "reproducibility_research_rigor": "applicable",
      "maintainability_operability": "not_applicable"
    },
    "expectations": [
      "reproduction instructions",
      "claim clarity",
      "artifact traceability"
    ]
  },
  "sdk": {
    "description": "Developer-facing software development kit with package integrity and API-consistency requirements.",
    "applicability_overrides": {
      "dependency_release_hygiene": "applicable",
      "documentation_truthfulness": "applicable",
      "testing_quality_gates": "applicable"
    },
    "expectations": [
      "API tests",
      "version discipline",
      "installation clarity",
      "developer documentation"
    ]
  },
  "infrastructure": {
    "description": "Infrastructure or automation repository, often heavy in shell, yaml, terraform, or deployment definitions.",
    "applicability_overrides": {
      "security_posture": "applicable",
      "maintainability_operability": "partially_applicable",
      "reproducibility_research_rigor": "not_applicable"
    },
    "expectations": [
      "safe defaults",
      "secrets discipline",
      "workflow hygiene",
      "rollback clarity"
    ]
  },
  "internal_tool": {
    "description": "Tool intended for internal operators or teams. May not need external-package polish but still requires safety and maintainability.",
    "applicability_overrides": {
      "documentation_truthfulness": "applicable",
      "maintainability_operability": "partially_applicable",
      "dependency_release_hygiene": "partially_applicable"
    },
    "expectations": [
      "clear operator guidance",
      "limited unsafe shortcuts",
      "reasonable maintenance path"
    ]
  }
}